# Expo public env var — sets the backend URL for the AI/OCR API.
# Points at the FastAPI backend (backend/, port 8000) for OCR invoice
# analysis and the AI advisory endpoints. Only needed to override the
# auto-derived default in src/config.ts.
#
# For a physical device on the same WiFi, replace 192.168.x.x with
# your dev machine's LAN IP shown by `ipconfig` (look for IPv4 Address).
#
# For Android emulator: use 10.0.2.2 instead of localhost
# For iOS simulator:    localhost works fine
#
# Uncomment ONE of the lines below:

# Local dev (iOS simulator)
# EXPO_PUBLIC_AI_API_URL=http://localhost:8000

# Local dev (Android emulator)
# EXPO_PUBLIC_AI_API_URL=http://10.0.2.2:8000

# Local dev (physical device on same WiFi — replace with your machine's IP)
# EXPO_PUBLIC_AI_API_URL=http://192.168.1.100:8000
